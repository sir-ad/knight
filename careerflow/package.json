{
  "name": "knight-extension",
  "displayName": "Knight",
  "version": "0.3.0",
  "description": "Knight - Universal Job Application & Tracking System - Privacy-first browser extension",
  "license": "MIT",
  "author": "sir-ad",
  "homepage": "https://sir-ad.github.io/knight/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sir-ad/knight.git",
    "directory": "careerflow"
  },
  "bugs": {
    "url": "https://github.com/sir-ad/knight/issues"
  },
  "keywords": [
    "chrome-extension",
    "job-search",
    "ats-autofill",
    "ollama",
    "gmail",
    "plasmo",
    "typescript"
  ],
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "mammoth": "^1.6.0",
    "pdf-parse": "^1.1.1",
    "plasmo": "^0.90.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@plasmohq/prettier-plugin-sort-imports": "^4.0.1",
    "@tailwindcss/forms": "^0.5.7",
    "@types/chrome": "^0.0.268",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.52",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-util": "^29.7.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "svgo": "^3.3.3",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "manifest": {
    "background": {
      "scripts": [
        "src/background/service-worker.ts"
      ]
    },
    "name": "Knight",
    "description": "Knight - Universal Job Application & Tracking System",
    "version": "0.1.2",
    "host_permissions": [
      "https://www.googleapis.com/*",
      "http://localhost:11434/*",
      "http://127.0.0.1:11434/*"
    ],
    "permissions": [
      "storage",
      "alarms",
      "identity",
      "notifications",
      "activeTab"
    ]
  }
}
